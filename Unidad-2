        {q:"Complete: La red que cubre una ciudad se llama ______.",type:"fill",correct:"MAN",hint:"Metropolitan Area Network"},
        {q:"¿Qué frecuencia Wi-Fi tiene mayor alcance pero está más saturada?",type:"mcq",opts:["2.4 GHz","5 GHz","6 GHz","60 GHz"],correct:"2.4 GHz"},
        {q:"PoE++ (802.3bt) entrega hasta 100W.",type:"tf",opts:["Verdadero","Falso"],correct:"Verdadero"},
        {q:"Complete: El registro de nombres de dominio a IP se resuelve con ______.",type:"fill",correct:"DNS",hint:"Domain Name System"},
        {q:"¿Qué clase IPv4 comienza con 1-126?",type:"mcq",opts:["Clase A","Clase B","Clase C","Clase D"],correct:"Clase A"},
        {q:"El gateway es la puerta de salida a Internet (router).",type:"tf",opts:["Verdadero","Falso"],correct:"Verdadero"},
        {q:"Complete: El comando que muestra el nombre de la PC es ______.",type:"fill",correct:"hostname",hint:"nombre equipo"},
        {q:"¿Cuántos watts entrega PoE básico (802.3af)?",type:"mcq",opts:["15.4W","30W","60W","100W"],correct:"15.4W"},
        {q:"La topología en anillo usa un token pasante para evitar colisiones.",type:"tf",opts:["Verdadero","Falso"],correct:"Verdadero"},
        {q:"Complete: La inmunidad a interferencias es característica de la fibra ______.",type:"fill",correct:"óptica",hint:"no eléctrica"},
        {q:"¿Qué comando permite consultar el servidor DNS forzadamente?",type:"mcq",opts:["ping","tracert","nslookup","netstat"],correct:"nslookup"},
        {q:"El conflicto de IP ocurre cuando una IP estática duplica una asignada por DHCP.",type:"tf",opts:["Verdadero","Falso"],correct:"Verdadero"},
        {q:"Complete: La subcapa que controla el acceso al medio físico dentro de la trama es ______.",type:"fill",correct:"MAC",hint:"Media Access Control"}
    ];

    let userAnswers = new Array(quizData.length).fill(null);
    let quizSubmitted = false;

    function renderQuiz() {
        const container = document.getElementById('quizContainer');
        if (!container) return;
        let html = '';
        quizData.forEach((q, idx) => {
            html += `<div class="quiz-question"><div class="question-text">${idx+1}. ${q.q}</div>`;
            if (q.type === "mcq" || q.type === "tf") {
                html += `<div class="options">`;
                q.opts.forEach(opt => {
                    const checked = (userAnswers[idx] === opt) ? 'checked' : '';
                    html += `<label class="option"><input type="radio" name="q${idx}" value="${opt.replace(/"/g, '&quot;')}" ${checked} data-qidx="${idx}" data-val="${opt}"><span>${opt}</span></label>`;
                });
                html += `</div>`;
            } else if (q.type === "fill") {
                let fillVal = (userAnswers[idx] && typeof userAnswers[idx] === 'string') ? userAnswers[idx] : '';
                html += `<div><input type="text" style="width:100%; padding:8px; border-radius:50px; border:1px solid #ccc;" placeholder="Escribe tu respuesta..." data-fillidx="${idx}" value="${fillVal.replace(/"/g, '&quot;')}"></div>`;
                if (q.hint) html += `<div class="feedback"><i class="fas fa-lightbulb"></i> Pista: ${q.hint}</div>`;
            }
            if (quizSubmitted && userAnswers[idx] !== null && userAnswers[idx] !== "") {
                const isCorrect = (userAnswers[idx].toString().toLowerCase() === q.correct.toString().toLowerCase());
                html += `<div class="feedback ${isCorrect ? 'correct-feedback' : 'wrong-feedback'}">${isCorrect ? '✓ Correcto' : `✗ Incorrecto. Respuesta: ${q.correct}`}</div>`;
            } else if (quizSubmitted && (!userAnswers[idx] || userAnswers[idx] === "")) {
                html += `<div class="feedback wrong-feedback">✗ Sin responder. Correcta: ${q.correct}</div>`;
            }
            html += `</div>`;
        });
        container.innerHTML = html;
        document.querySelectorAll('input[type="radio"]').forEach(radio => {
            radio.addEventListener('change', (e) => {
                const qIdx = parseInt(radio.getAttribute('data-qidx'));
                if (!isNaN(qIdx)) userAnswers[qIdx] = radio.value;
            });
        });
        document.querySelectorAll('input[type="text"]').forEach(inp => {
            inp.addEventListener('input', (e) => {
                const idx = parseInt(inp.getAttribute('data-fillidx'));
                if (!isNaN(idx)) userAnswers[idx] = inp.value.trim();
            });
        });
    }

    function calculateScore() {
        let score = 0;
        for (let i=0; i<quizData.length; i++) {
            let ans = userAnswers[i] ? userAnswers[i].toString().trim().toLowerCase() : "";
            let correctAns = quizData[i].correct.toString().toLowerCase();
            if (ans === correctAns) score++;
        }
        return score;
    }

    function updateScorePanel() {
        const panel = document.getElementById('scorePanel');
        const score = calculateScore();
        panel.innerHTML = `<i class="fas fa-star"></i> Puntuación final: ${score} / ${quizData.length} (${Math.round(score/quizData.length*100)}%) — ${score === quizData.length ? '¡Perfecto!' : 'Repasa la infografía'}`;
    }

    document.getElementById('submitQuiz')?.addEventListener('click', () => { quizSubmitted = true; renderQuiz(); updateScorePanel(); });
    document.getElementById('resetQuiz')?.addEventListener('click', () => { userAnswers = new Array(quizData.length).fill(null); quizSubmitted = false; renderQuiz(); document.getElementById('scorePanel').innerHTML = ''; });

    const btnInfo = document.getElementById('btnInfografia'), btnQuiz = document.getElementById('btnQuiz');
    const secInfo = document.getElementById('infografiaSection'), secQuiz = document.getElementById('quizSection');
    btnInfo.addEventListener('click', () => { btnInfo.classList.add('active'); btnQuiz.classList.remove('active'); secInfo.classList.add('active-section'); secQuiz.classList.remove('active-section'); });
    btnQuiz.addEventListener('click', () => { btnQuiz.classList.add('active'); btnInfo.classList.remove('active'); secQuiz.classList.add('active-section'); secInfo.classList.remove('active-section'); renderQuiz(); updateScorePanel(); });
    renderQuiz();
</script>
</body>
</html>
